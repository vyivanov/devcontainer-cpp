{
  "name": "C++",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "username": "${localEnv:USER}"
    }
  },
  "containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}",
    "LANG": "${localEnv:LANG}"
  },
  "runArgs": [
    "--net=host",
    "--privileged"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "workspaceFolder": "/workspace",
  "mounts": ["source=/dev,target=/dev,type=bind"]
}
